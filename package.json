{
  "name": "inbola-marketplace",
  "version": "1.0.0",
  "description": "INBOLA Kids Marketplace - Professional E-commerce Platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend-main && npm run dev",
    "dev:frontend": "cd front-main && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend-main && npm run build",
    "build:frontend": "cd front-main && npm run build",
    "start": "pm2 start ecosystem.config.js --env production",
    "stop": "pm2 stop all",
    "restart": "pm2 restart all",
    "status": "pm2 status",
    "logs": "pm2 logs",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend-main && npm run test",
    "test:frontend": "cd front-main && npm run test",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend-main && npm run lint",
    "lint:frontend": "cd front-main && npm run lint",
    "setup": "./scripts/development/setup.sh",
    "deploy": "./scripts/deployment/FINAL_PRODUCTION_DEPLOY.sh",
    "clean": "rm -rf node_modules backend-main/node_modules front-main/node_modules",
    "install:all": "npm install && cd backend-main && npm install && cd ../front-main && npm install && cd .."
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "pm2": "^6.0.8",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Xorazm92/marketplace.git"
  },
  "keywords": [
    "ecommerce",
    "marketplace",
    "kids",
    "nextjs",
    "nestjs",
    "typescript",
    "postgresql",
    "graphql"
  ],
  "author": "INBOLA Development Team",
  "license": "MIT"
}
